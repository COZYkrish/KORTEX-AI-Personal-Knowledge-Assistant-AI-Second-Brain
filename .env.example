# ==================================================
# KORTEX AI — Environment Variables
# Copy this file to .env and fill in all values.
# ==================================================

# --------------------------------------------------
# DATABASE (PostgreSQL + pgvector)
# Recommended: Supabase or Neon
# --------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/kortex?sslmode=require"

# --------------------------------------------------
# REDIS (BullMQ Queue)
# Recommended: Upstash Redis
# --------------------------------------------------
REDIS_URL="redis://default:PASSWORD@HOST:6379"

# --------------------------------------------------
# CLERK AUTHENTICATION
# https://dashboard.clerk.com
# --------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# --------------------------------------------------
# GOOGLE GEMINI AI
# https://aistudio.google.com/app/apikey
# --------------------------------------------------
GEMINI_API_KEY="AIzaSyAQ..."

# --------------------------------------------------
# OPENAI — NOT REQUIRED
# Embeddings: BAAI/bge-small-en-v1.5 (local, free via @xenova/transformers)
# Voice: Browser Web Speech API (free, no API needed)
# --------------------------------------------------
# OPENAI_API_KEY="" ← Leave blank or omit entirely

# --------------------------------------------------
# FILE STORAGE (Vercel Blob or AWS S3)
# --------------------------------------------------
BLOB_READ_WRITE_TOKEN=""

# --------------------------------------------------
# APPLICATION
# --------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Kortex AI"
NODE_ENV="development"
